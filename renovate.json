{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "packageRules": [
    {
      "description": "Group GHA",
      "enabled": true,
      "groupName": "gha",
      "matchFileNames": [".github/**"]
    },
    {
      "description": "Docker image",
      "enabled": true,
      "groupName": "docker images",
      "matchFileNames": ["docker/**"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Consolidated version/image updates for Makefile and .deps yaml files",
      "managerFilePatterns": ["/^Makefile$/", "/^.deps/.*.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>[^\\s]+)(?: extractVersion=(?<extractVersion>[^\\s]+))?\\n(?:(?<varName>[A-Z0-9_]+) ?\\?= ?|version: )(?<currentValue>.*)"
      ],
      "datasourceTemplate": "{{{ datasource }}}",
      "depNameTemplate": "{{{ depName }}}",
      "extractVersionTemplate": "{{{ extractVersion }}}"
    }
  ]
  "prHourlyLimit": 5
}
